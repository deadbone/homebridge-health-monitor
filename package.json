{
  "name": "homebridge-health-monitor",
  "displayName": "Homebridge Health Monitor",
  "type": "module",
  "version": "0.1.0-alpha.3",
  "private": false,
  "description": "Homebridge plugin that monitors the Homebridge log file and exposes health anomalies through a single HomeKit Leak Sensor.",
  "author": "Thierry Lubrez",
  "license": "Apache-2.0",
  "homepage": "https://github.com/deadbone/homebridge-health-monitor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deadbone/homebridge-health-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/deadbone/homebridge-health-monitor/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "health",
    "monitor",
    "logs",
    "errors",
    "warnings"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "assets",
    "config.schema.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "homebridge": "^1.6.0 || ^2.0.0",
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "prepare": "npm run build",
    "verify:pack": "node tools/verify-pack.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run lint && npm run build && npm test && npm run verify:pack"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.0",
    "homebridge": "^2.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
